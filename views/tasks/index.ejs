<h2>Taskuri</h2>

<label><input type="radio" name="s" value="pending">pending</label>
<label><input type="radio" name="s" value="ongoing">ongoing</label>
<label><input type="radio" name="s" value="completed">completed</label>

<div id="out"></div>

<script>
function load(status){
  fetch("/api/tasks?status="+status)
  .then(r=>r.json())
  .then(data=>{
    let html="<table border=1>";
    data.forEach(t=>{
      html+=`<tr><td>${t.title}</td><td>${t.status}</td></tr>`
    });
    html+="</table>";
    document.getElementById("out").innerHTML=html;
  });
}

document.querySelectorAll("input").forEach(r=>{
  r.onchange=()=>load(r.value);
});
</script>